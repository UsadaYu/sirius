prefix=@CMAKE_INSTALL_PREFIX@
includedir=${prefix}/include

Name: @SIRIUS_TARGET_SIRIUS_LIBRARY_NAME@
Description: sirius
Version: @SIRIUS_VERSION@
URL: https://github.com/UsadaYu/sirius
Libs: @_pkg_interface_link_dir@ @_pkg_interface_link_libraries@
Libs.private: @_pkg_interface_private_link_dir@ @_pkg_interface_private_link_libraries@
Cflags: -I${includedir} @_pkg_interface_cflags@
